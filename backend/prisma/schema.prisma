generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  doctor    Doctor?

  @@index([role])
  @@index([createdAt])
}

model Doctor {
  id              String        @id @default(uuid())
  userId          String?       @unique
  name            String
  specialization  String
  department      String
  consultationFee Float
  experience      Int
  availableFrom   String        @default("09:00")
  availableTo     String        @default("17:00")
  createdAt       DateTime      @default(now())
  appointments    Appointment[]
  user            User?         @relation(fields: [userId], references: [id])
  queueTokens     QueueToken[]

  @@index([specialization])
  @@index([department])
  @@index([createdAt])
}

model Patient {
  id             String        @id @default(uuid())
  name           String
  email          String?
  phoneNumber    String
  age            Int
  gender         String
  medicalHistory String?
  createdAt      DateTime      @default(now())
  appointments   Appointment[]
  queueTokens    QueueToken[]

  @@index([name])
  @@index([phoneNumber])
  @@index([email])
  @@index([createdAt])
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  doctorId        String
  appointmentDate DateTime
  reason          String            @default("")
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  queueTokens     QueueToken[]

  @@unique([doctorId, appointmentDate])
  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentDate])
  @@index([status])
  @@index([doctorId, status])
  @@index([createdAt])
}

model QueueToken {
  id            String       @id @default(uuid())
  tokenNumber   Int
  patientId     String
  doctorId      String
  appointmentId String?
  status        QueueStatus  @default(WAITING)
  createdAt     DateTime     @default(now())
  queueDate     DateTime     @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  patient       Patient      @relation(fields: [patientId], references: [id])

  @@unique([doctorId, queueDate, tokenNumber])
  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([status])
  @@index([doctorId, createdAt])
  @@index([queueDate])
  @@index([createdAt])
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}
